# Event Service Environment Variables
SERVER_PORT=8085
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/englishflow_event_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
EUREKA_INSTANCE_HOSTNAME=localhost

# Twilio Configuration (SMS Reminders)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Club Service URL (Feign Client)
CLUB_SERVICE_URL=http://localhost:8086

# Sponsors Service URL (Feign Client)
SPONSORS_SERVICE_URL=http://localhost:8092

# WebSocket Configuration
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:4200
