# Messaging Service Environment Variables
SERVER_PORT=8084
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=englishflow_messaging_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis Configuration (for WebSocket sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
EUREKA_INSTANCE_HOSTNAME=localhost

# JWT Configuration
JWT_SECRET=your-secure-jwt-secret-key-minimum-256-bits-change-in-production

# WebSocket Configuration
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:4200

# Rate Limiting
RATE_LIMIT_MESSAGES_PER_MINUTE=60

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_DIR=./uploads
