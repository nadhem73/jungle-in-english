# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/englishflow_identity
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Configuration (IMPORTANT: Change in production!)
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-key-here-minimum-256-bits-recommended
JWT_EXPIRATION=86400000

# Email Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# reCAPTCHA Configuration
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Meeting Platforms Configuration
# Google Meet (via Google Calendar API)
GOOGLE_MEET_ENABLED=false
# Pour activer Google Meet, suivez ces étapes:
# 1. Créer un projet sur https://console.cloud.google.com/
# 2. Activer Google Calendar API
# 3. Créer des credentials (Service Account)
# 4. Télécharger le fichier JSON des credentials
# 5. Placer le fichier dans: backend/auth-service/credentials/google-calendar-credentials.json
# GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials/google-calendar-credentials.json

# Zoom (via Zoom API)
ZOOM_ENABLED=false
# Pour activer Zoom, suivez ces étapes:
# 1. Créer une Server-to-Server OAuth app sur https://marketplace.zoom.us/
# 2. Obtenir Account ID, Client ID et Client Secret
# ZOOM_ACCOUNT_ID=your-zoom-account-id
# ZOOM_CLIENT_ID=your-zoom-client-id
# ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Microsoft Teams (via Microsoft Graph API)
TEAMS_ENABLED=false
# Pour activer Teams, suivez ces étapes:
# 1. Enregistrer une app sur https://portal.azure.com/
# 2. Configurer les permissions Microsoft Graph (OnlineMeetings.ReadWrite)
# 3. Obtenir Tenant ID, Client ID et Client Secret
# TEAMS_TENANT_ID=your-teams-tenant-id
# TEAMS_CLIENT_ID=your-teams-client-id
# TEAMS_CLIENT_SECRET=your-teams-client-secret
