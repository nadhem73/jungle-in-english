# Service Configuration
SERVICE_NAME=ml-service
SERVICE_PORT=8093
SERVICE_HOST=0.0.0.0

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_INSTANCE_HOSTNAME=localhost
EUREKA_INSTANCE_PORT=8093

# Microservices URLs
AUTH_SERVICE_URL=http://localhost:8081
COURSES_SERVICE_URL=http://localhost:8082
LEARNING_SERVICE_URL=http://localhost:8083
GAMIFICATION_SERVICE_URL=http://localhost:8088

# ML Models Path
MODELS_PATH=./app/models

# API Configuration
API_PREFIX=/api/ml
API_VERSION=v1

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# Logging
LOG_LEVEL=INFO
