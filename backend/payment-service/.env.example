# Payment Service Environment Variables
SERVER_PORT=8089
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/englishflow_payment
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka/
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false
EUREKA_INSTANCE_HOSTNAME=localhost

# Paymee Configuration
PAYMEE_API_KEY=your-paymee-api-key
PAYMEE_SECRET_KEY=your-paymee-secret-key
PAYMEE_API_URL=https://api.paymee.tn

# Konnect Configuration
KONNECT_API_KEY=your-konnect-api-key
KONNECT_WALLET_ID=your-konnect-wallet-id
KONNECT_API_URL=https://api.konnect.network

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret
