# EnglishFlow - Global Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==================== Database Configuration ====================
DB_PASSWORD=postgres123
DB_USERNAME=postgres
DB_HOST=localhost
DB_PORT=5432

# ==================== JWT Configuration ====================
# IMPORTANT: Generate a secure 256-bit key for production
# You can use: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-key-minimum-256-bits-change-in-production

# ==================== Redis Configuration ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Frontend Configuration ====================
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:8080

# ==================== Email Configuration (Gmail) ====================
# For Gmail: Use App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ==================== OAuth2 Configuration ====================
# Google OAuth2 (for Sign-In with Google)
# Get credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==================== reCAPTCHA Configuration ====================
# Get keys: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=your-recaptcha-secret-key

# ==================== Twilio Configuration (SMS) ====================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== Payment Gateway Configuration ====================
# Paymee
PAYMEE_API_KEY=your-paymee-api-key
PAYMEE_SECRET_KEY=your-paymee-secret-key

# Konnect
KONNECT_API_KEY=your-konnect-api-key
KONNECT_WALLET_ID=your-konnect-wallet-id

# ==================== Monitoring Configuration ====================
# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ==================== Docker Registry ====================
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/englishflow

# ==================== Deployment Configuration ====================
ENVIRONMENT=development
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev
